# ================================================================
#  Multi-Agent Medical Chatbot — Environment Configuration
#  Rename this file to .env and replace all placeholder values
# ================================================================

# ── LLM (Azure OpenAI) ──────────────────────────────────────────
AZURE_DEPLOYMENT_NAME=<your-gpt4o-deployment-name>
AZURE_MODEL_NAME=gpt-4o
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Rename above keys to match variable names in config.py:
deployment_name=<your-gpt4o-deployment-name>
model_name=gpt-4o
azure_endpoint=https://<your-resource-name>.openai.azure.com/
openai_api_key=<your-azure-openai-api-key>
openai_api_version=2024-02-15-preview

# ── Embeddings (Azure OpenAI) ────────────────────────────────────
embedding_deployment_name=<your-embedding-deployment-name>
embedding_model_name=text-embedding-3-large
embedding_azure_endpoint=https://<your-resource-name>.openai.azure.com/
embedding_openai_api_key=<your-azure-embedding-api-key>
embedding_openai_api_version=2024-02-15-preview

# ── Vector Database (Qdrant) ─────────────────────────────────────
# Leave blank to run Qdrant locally (default)
QDRANT_URL=
QDRANT_API_KEY=

# ── Web Search ───────────────────────────────────────────────────
TAVILY_API_KEY=<your-tavily-api-key>
# Get your key at: https://app.tavily.com

# ── Speech (ElevenLabs) ──────────────────────────────────────────
ELEVEN_LABS_API_KEY=<your-elevenlabs-api-key>
# Get your key at: https://elevenlabs.io

# ── Model Downloads (HuggingFace) ────────────────────────────────
HUGGINGFACE_TOKEN=<your-huggingface-access-token>
# Required to download the cross-encoder reranker model
# Get your token at: https://huggingface.co/settings/tokens
